{
	"name": "@trustwallet/connect-bip122-react",
	"version": "0.0.0",
	"description": "React hooks for Bitcoin namespace in TrustConnect SDK",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"clean": "rm -rf dist"
	},
	"keywords": [
		"trust",
		"connect",
		"sdk",
		"bitcoin",
		"react",
		"hooks"
	],
	"author": "",
	"license": "Apache-2.0",
	"dependencies": {
		"@trustwallet/connect-bip122-core": "workspace:*",
		"@trustwallet/connect-utils": "workspace:*",
		"@trustwallet/connect-headless": "workspace:*"
	},
	"peerDependencies": {
		"@tanstack/react-query": "^5.0.0",
		"@trustwallet/connect-core": "workspace:*",
		"react": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@tanstack/react-query": "5.90.15",
		"@types/react": "19.2.7",
		"react": "19.2.3"
	}
}
