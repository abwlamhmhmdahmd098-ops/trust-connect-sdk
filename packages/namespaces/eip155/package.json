{
	"name": "@trustwallet/connect-eip155-core",
	"version": "0.0.0-alpha.11",
	"description": "EIP-155 (Ethereum) namespace core implementation for TrustConnect SDK",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"clean": "rm -rf dist"
	},
	"keywords": [
		"trust",
		"connect",
		"sdk",
		"ethereum",
		"eip155",
		"core"
	],
	"author": "",
	"license": "Apache-2.0",
	"dependencies": {
		"@trustwallet/connect-core": "workspace:*",
		"@trustwallet/connect-eip155-types": "workspace:*"
	}
}
