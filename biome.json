{
	"$schema": "https://biomejs.dev/schemas/2.3.9/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": false
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded",
			"quoteStyle": "single",
			"lineWidth": 120
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "off"
			}
		}
	},
	"files": {
		"includes": ["**/src/**/*.ts", "**/src/**/*.tsx"]
	}
}
